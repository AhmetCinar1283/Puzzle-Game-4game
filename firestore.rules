rules_version = '2';

  service cloud.firestore {
    match /databases/{database}/documents {

      function isSignedIn() { return request.auth != null; }
      function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
      function isAdmin() {
        return isSignedIn() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
      function isModerator() {
        return isSignedIn() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
            in ['admin', 'moderator'];
      }
      function isNotAnonymous() {
        return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
      }

      // Checks whether the current user is allowed to read a level document.
      // - Moderators/admins bypass all restrictions.
      // - First level of a part (no prevLevelId): requires totalScore >= unlockRequirement.
      // - Subsequent levels: requires the previous level to be in playedLevels.
      function canReadLevel() {
        if (isModerator()) return true;
        if (!isSignedIn()) return false;

        let d = resource.data;

        if (!('prevLevelId' in d) || d.prevLevelId == null) {
          // First level in part — check totalScore >= unlockRequirement
          let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
          let partData = get(/databases/$(database)/documents/levelParts/$(d.part)).data;
          return userData.totalScore >= partData.unlockRequirement;
        }

        // Not first — check if previous level was completed
        return exists(
          /databases/$(database)/documents/users/$(request.auth.uid)/playedLevels/$(d.prevLevelId)
        );
      }

      match /users/{uid} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
              'uid','authProvider','createdAt','totalScore','completedCount',
              'role','email','displayName'
            ])
          && request.resource.data.uid == uid
          && request.resource.data.totalScore == 0
          && request.resource.data.completedCount == 0
          && request.resource.data.role == 'user';

        // Clients may update profile fields only — totalScore and completedCount are worker-only
        allow update: if isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['totalScore', 'completedCount', 'role'])
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.createdAt == resource.data.createdAt
          && (!('tag' in resource.data) || request.resource.data.tag == resource.data.tag);

        // playedLevels are written exclusively by the Cloudflare Worker (Admin SDK bypasses rules)
        match /playedLevels/{levelId} {
          allow read: if isOwner(uid);
          allow write: if false;
        }
      }

      // Tags registry — written exclusively by Cloud Functions (Admin SDK bypasses rules)
      match /tags/{tag} {
        allow read, write: if false;
      }

      match /levels/{levelId} {
        allow read: if canReadLevel();
        allow write: if isAdmin();

        // solutions and other infos written exclusively by the Cloudflare Worker
        match /infos/{doc} {
          allow read: if true;
          allow write: if false;
        }
      }

      match /levelParts/{partId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /levelRequests/{requestId} {
        // Single-doc read: owner or admin; list: admin only
        allow get: if isOwner(resource.data.submittedBy) || isAdmin();
        allow list: if isAdmin();
        // Non-anonymous users can create their own requests (status must start as 'pending')
        allow create: if isNotAnonymous()
          && request.resource.data.submittedBy == request.auth.uid
          && request.resource.data.status == 'pending';
        // Only admin can approve/reject (update status)
        allow update: if isAdmin();
        // Owner can delete their own pending request
        allow delete: if isOwner(resource.data.submittedBy)
          && resource.data.status == 'pending';
      }

      match /{document=**} { allow read, write: if false; }
    }
  }
